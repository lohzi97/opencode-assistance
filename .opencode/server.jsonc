{
  // Optional IANA timezone for cron evaluation.
  // If omitted, the machine local timezone is used.
  "timezone": "Asia/Kuala_Lumpur",
  "jobs": [
    {
      "id": "daily-journal-writter",
      "title": "Write Daily Journal",
      "cron": "5 0 * * *",
      "prompt": "/write-diary",
      "enabled": true,
      "no_overlap": true
    },
    {
      "id": "memory-updater-today",
      "title": "Update today memory",
      "cron": "0 * * * *",
      "prompt": "/update-today-memory",
      "enabled": true,
      "no_overlap": true
    }
  ]
}