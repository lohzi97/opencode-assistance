{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5.1",
  "small_model": "github-copilot/gpt-5-mini",
  "compaction": {
    "auto": false
  },
  "provider": {
    "openrouter": {
      "models": {
        "deepseek/deepseek-v3.2": {
          "options": {
            "provider": {
              "max_price": {
                "prompt": 0.29,
                "completion": 0.43
              },
              "sort": "price",
              "require_parameters": true,
              "allow_fallbacks": true
            },
            "reasoning": {
              "enabled": true
            }
          }
        }
      }
    }
  },
  "plugin": [
    "opencode-pty"
  ],
  "permission": {
    "edit": {
      "AGENTS.md": "deny"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222"
      ],
    },
    "brave-search": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:9999/mcp",
      "oauth": false
    },
    "computer-control": {
      "enabled": true,
      "type": "local",
      "command": [
        "uvx",
        "--python",
        "3.13",
        "computer-control-mcp@latest"
      ]
    }
  }
}
